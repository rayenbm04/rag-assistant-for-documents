# Copy this file to .env and adjust values for your setup
# .env is gitignored — never commit it

# ── Ollama models ──────────────────────────────────────────────
# Text generation model (must be pulled: ollama pull mistral:7b-instruct-q4_K_M)
LLM_MODEL=mistral:7b-instruct-q4_K_M

# Embedding model (must be pulled: ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text

# Vision model for images/PDFs (must be pulled: ollama pull llava)
VISION_MODEL=llava

# ── Storage paths ──────────────────────────────────────────────
# Relative to the directory where uvicorn is launched (rag-backend/)
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db

# ── API settings ───────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Max file upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Number of chunks retrieved per RAG query
SIMILARITY_TOP_K=4

# ── Streaming ──────────────────────────────────────────────────
# Delay between streamed characters in milliseconds (increase to slow down)
STREAM_DELAY_MS=20

# ── Ollama connection ──────────────────────────────────────────
# Default: local. In Docker, set to http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── RAG evaluation ─────────────────────────────────────────────
# Set to false to skip faithfulness / relevance scoring after each answer
# (each eval fires 2 extra LLM calls — disable if latency is a concern)
ENABLE_EVAL=true
